{
  "productName": "SpoitableHRS",
  "version": "0.1.2",
  "identifier": "com.spoitable.hrs",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SpoitableHRS",
        "width": 450,
        "height": 720,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://spoitable.update.f2a.dev/update/{{target}}/{{current_version}}"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCN0U4MTAwMzc3NjdDQTYKUldTbWZIWTNBSUYreTFxVUFNeVlDUU1UTHFrUnk4UW1qN00ydFkrZHdQTmhDbEZRZFpDUWZiWW0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "SpoitableHRS",
        "headerImage": null,
        "sidebarImage": null
      }
    }
  }
}
